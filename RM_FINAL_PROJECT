# transfer.py
# Inventor project transfer: IAM -> Pack&Go (shell verb like PPM) -> copy extras -> zip local RYSUNKI -> report
# Requirements: Windows, Python 3.10+, pywin32 (pip install pywin32)

from __future__ import annotations

import json
