import shutil
import sys
import time
import zipfile
import unicodedata
from dataclasses import dataclass, asdict
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Tuple

import tkinter as tk
from tkinter import filedialog, messagebox

import logging


# =========================
# CONFIG
# =========================

RYSUNKI_PREFIX = "RYSUNKI"  # foldery zaczynające się od tego prefiksu

EXTENSIONS_TO_COPY = {
    ".dxf", ".dwf", ".pdf", ".xlsx", ".csv", ".jpg", ".bmp"
}

def detect_inventor_public_root() -> Path:
    base = Path(r"C:\Users\Public\Documents\Autodesk")
    # spróbuj znaleźć najwyższą zainstalowaną wersję Inventora
    # np. "Inventor 2013", "Inventor 2015"...
    candidates = sorted([p for p in base.glob("Inventor *") if p.is_dir()], reverse=True)
    if candidates:
        return candidates[0]
    return base / "Inventor 2015"  # fallback

# Monitor zakończenia Pack&Go
POLL_SECONDS = 2
STABILIZATION_SECONDS = 12  # ile sekund brak zmian, żeby uznać "skończone"
LOCK_TEST_SAMPLES = 10      # ile plików próbować otworzyć do odczytu

# Bezpieczeństwo
FAIL_IF_DEST_EXISTS = True  # jeśli PROJEKT_X już istnieje -> STOP (True) / dopisz _01 (False)
DRY_RUN = False             # True = nic nie kopiuje/usuwa, tylko raportuje co by zrobił

# Pack&Go shell verb targets (PL/EN)
PACKGO_TARGETS = [
    "pack and go",
    "spakuj i przenies",
]


# =========================
# DATA STRUCTURES
# =========================

@dataclass
class CopyStats:
    files: int = 0
    bytes: int = 0
    by_ext: Dict[str, int] = None

    def __post_init__(self):
        if self.by_ext is None:
            self.by_ext = {}

    def add_file(self, path: Path):
        self.files += 1
        try:
            sz = path.stat().st_size
        except OSError:
            sz = 0
        self.bytes += sz
        ext = path.suffix.lower()
        self.by_ext[ext] = self.by_ext.get(ext, 0) + 1


@dataclass
class RunReport:
    timestamp_start: str
    timestamp_end: str = ""
    user: str = ""
    python_exe: str = ""
    source_iam: str = ""
    source_root: str = ""
    source_ipj: str = ""
    server_project_dir: str = ""

    packngo_detected_files: int = 0
    packngo_detected_bytes: int = 0

    copied_rysunki_dirs: List[str] = None
    copied_rysunki_stats: CopyStats = None

    copied_root_files_stats: CopyStats = None
    copied_templates_stats: CopyStats = None
    copied_design_data_stats: CopyStats = None

    local_zip_path: str = ""
    local_zip_bytes: int = 0
    local_zip_entries: int = 0
    deleted_local_rysunki_dirs: List[str] = None

    errors: List[str] = None
    warnings: List[str] = None

    def __post_init__(self):
        if self.copied_rysunki_dirs is None:
            self.copied_rysunki_dirs = []
        if self.copied_rysunki_stats is None:
            self.copied_rysunki_stats = CopyStats()
        if self.copied_root_files_stats is None:
            self.copied_root_files_stats = CopyStats()
        if self.copied_templates_stats is None:
            self.copied_templates_stats = CopyStats()
        if self.copied_design_data_stats is None:
            self.copied_design_data_stats = CopyStats()
        if self.deleted_local_rysunki_dirs is None:
            self.deleted_local_rysunki_dirs = []
        if self.errors is None:
            self.errors = []
        if self.warnings is None:
            self.warnings = []


# =========================
# HELPERS
